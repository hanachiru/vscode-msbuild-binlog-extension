{
  "name": "vscode-msbuild-binlog-extension",
  "displayName": "MSBuild Binlog Viewer",
  "description": "View MSBuild .binlog files in VS Code.",
  "version": "0.0.2",
  "publisher": "hanachiru",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanachiru/vscode-msbuild-binlog-extension.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:msbuildBinlog.viewer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "msbuildBinlog.viewer",
        "displayName": "MSBuild Binlog Viewer",
        "selector": [
          {
            "filenamePattern": "*.binlog"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json && tsc -p ./tsconfig.webview.json",
    "compile:helper": "dotnet build ./vscode-msbuild-binlog-extension.slnx",
    "watch": "tsc -w -p ./tsconfig.json"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^6.0.3"
  }
}
