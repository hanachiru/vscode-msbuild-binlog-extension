{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/webview/main.ts",
    "node_modules",
    ".vscode-test"
  ]
}